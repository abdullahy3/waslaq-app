#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android build artifacts
/android/app/debug
/android/app/profile
/android/app/release
/android/build/
android/local.properties

# iOS build artifacts (iOS build not used — Android only)
ios/Pods/
ios/build/
ios/.symlinks/
ios/Flutter/flutter_export_environment.sh

# Fix/patch scripts (dev-only utilities)
fix_*.py
fix_*.js
patch_*.py

# Build logs and debug output
build_out.txt
*.log
firebase-debug.log

# Temporary test files
test_json.dart

# Firebase config — contains API keys, never commit
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Build reports and debug artifacts
android/build/reports/
deps.txt
bug.md
.DS_Store
*.DS_Store

# Graphify AST cache (intermediate build artifacts — graph.json/GRAPH_REPORT.md are tracked)
graphify-out/cache/ast/
graphify-out/cache/stat-index.json
